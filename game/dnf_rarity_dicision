import sys
import re
from PySide6.QtWidgets import (
    QApplication, QMainWindow, QTabWidget, QWidget, QVBoxLayout, QHBoxLayout,
    QFormLayout, QDoubleSpinBox, QLabel, QPushButton, QTextEdit, QPlainTextEdit,
    QMessageBox
)
from PySide6.QtCore import Qt, Signal
from PySide6.QtGui import QClipboard

class DropRateTool(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("掉落爆率配置工具")
        self.resize(650, 500)

        self.tabs = QTabWidget()
        self.setCentralWidget(self.tabs)

        self.generator_tab = GeneratorTab()
        self.analyzer_tab = AnalyzerTab()

        self.tabs.addTab(self.generator_tab, "生成爆率数据")
        self.tabs.addTab(self.analyzer_tab, "分析已有数据")

class GeneratorTab(QWidget):
    def __init__(self):
        super().__init__()
        self.init_ui()

    def init_ui(self):
        layout = QVBoxLayout(self)

        # 输入区域
        form_layout = QFormLayout()
        self.spin_white = QDoubleSpinBox()
        self.spin_white.setRange(0.0, 100.0)
        self.spin_white.setDecimals(2)
        self.spin_white.setSuffix("%")
        self.spin_white.setValue(42.0)

        self.spin_blue = QDoubleSpinBox()
        self.spin_blue.setRange(0.0, 100.0)
        self.spin_blue.setDecimals(2)
        self.spin_blue.setSuffix("%")
        self.spin_blue.setValue(32.0)

        self.spin_purple = QDoubleSpinBox()
        self.spin_purple.setRange(0.0, 100.0)
        self.spin_purple.setDecimals(2)
        self.spin_purple.setSuffix("%")
        self.spin_purple.setValue(21.0)

        self.spin_pink = QDoubleSpinBox()
        self.spin_pink.setRange(0.0, 100.0)
        self.spin_pink.setDecimals(2)
        self.spin_pink.setSuffix("%")
        self.spin_pink.setValue(2.5)

        self.spin_yellow = QDoubleSpinBox()
        self.spin_yellow.setRange(0.0, 100.0)
        self.spin_yellow.setDecimals(2)
        self.spin_yellow.setSuffix("%")
        self.spin_yellow.setValue(2.5)

        form_layout.addRow("白色爆率", self.spin_white)
        form_layout.addRow("蓝色爆率", self.spin_blue)
        form_layout.addRow("紫色爆率", self.spin_purple)
        form_layout.addRow("粉色爆率", self.spin_pink)
        form_layout.addRow("黄色爆率", self.spin_yellow)

        layout.addLayout(form_layout)

        # 总和显示
        sum_layout = QHBoxLayout()
        self.sum_label = QLabel("总和: 100.00%")
        self.sum_label.setStyleSheet("font-weight: bold; color: green;")
        sum_layout.addWidget(self.sum_label)
        sum_layout.addStretch()
        layout.addLayout(sum_layout)

        # 生成按钮
        self.btn_generate = QPushButton("生成爆率数组")
        self.btn_generate.clicked.connect(self.generate)
        layout.addWidget(self.btn_generate)

        # 输出显示
        self.output_text = QTextEdit()
        self.output_text.setReadOnly(True)
        layout.addWidget(self.output_text)

        # 复制按钮
        self.btn_copy = QPushButton("复制到剪贴板")
        self.btn_copy.clicked.connect(self.copy_to_clipboard)
        layout.addWidget(self.btn_copy)

        # 连接信号，实时更新总和
        self.spin_white.valueChanged.connect(self.update_sum)
        self.spin_blue.valueChanged.connect(self.update_sum)
        self.spin_purple.valueChanged.connect(self.update_sum)
        self.spin_pink.valueChanged.connect(self.update_sum)
        self.spin_yellow.valueChanged.connect(self.update_sum)

        self.update_sum()

    def update_sum(self):
        total = (self.spin_white.value() + self.spin_blue.value() +
                 self.spin_purple.value() + self.spin_pink.value() +
                 self.spin_yellow.value())
        self.sum_label.setText(f"总和: {total:.2f}%")
        if abs(total - 100.0) < 1e-6:
            self.sum_label.setStyleSheet("font-weight: bold; color: green;")
            self.btn_generate.setEnabled(True)
        else:
            self.sum_label.setStyleSheet("font-weight: bold; color: red;")
            self.btn_generate.setEnabled(False)

    def generate(self):
        percentages = [
            self.spin_white.value(),
            self.spin_blue.value(),
            self.spin_purple.value(),
            self.spin_pink.value(),
            self.spin_yellow.value()
        ]
        # 将百分比转换为宽度（四舍五入到整数）
        widths = [round(p / 100.0 * 1_000_000) for p in percentages]
        total_width = sum(widths)

        # 因为四舍五入可能导致总和不等于1000000，调整最后一个品级（黄色）
        diff = 1_000_000 - total_width
        if diff != 0:
            # 调整黄色宽度
            widths[-1] += diff
            if widths[-1] < 0:
                QMessageBox.warning(self, "精度错误", "由于四舍五入导致黄色概率为负，请调整输入精度。")
                return

        # 生成累积阈值
        thresholds = []
        cum = 0
        for i, w in enumerate(widths):
            cum += w
            thresholds.append(cum)
        # 添加哨兵值
        thresholds.append(1_000_001)

        # 格式化输出字符串：每个数字前加制表符，数字间也用制表符分隔
        output_str = "\t" + "\t".join(str(t) for t in thresholds)
        self.output_text.setPlainText(output_str)

    def copy_to_clipboard(self):
        text = self.output_text.toPlainText()
        if text:
            QApplication.clipboard().setText(text)
            QMessageBox.information(self, "已复制", "爆率数组已复制到剪贴板。")
        else:
            QMessageBox.warning(self, "无内容", "请先生成数据。")


class AnalyzerTab(QWidget):
    def __init__(self):
        super().__init__()
        self.init_ui()

    def init_ui(self):
        layout = QVBoxLayout(self)

        label = QLabel("粘贴爆率数据（每组6个数字，可用制表符/空格/换行分隔）：")
        layout.addWidget(label)

        self.input_text = QPlainTextEdit()
        layout.addWidget(self.input_text)

        self.btn_analyze = QPushButton("分析爆率")
        self.btn_analyze.clicked.connect(self.analyze)
        layout.addWidget(self.btn_analyze)

        self.result_text = QTextEdit()
        self.result_text.setReadOnly(True)
        layout.addWidget(self.result_text)

    def analyze(self):
        raw_text = self.input_text.toPlainText()
        if not raw_text.strip():
            self.result_text.setPlainText("请先粘贴数据。")
            return

        # 分割出所有数字（支持制表符、空格、换行等空白字符）
        tokens = re.split(r'\s+', raw_text.strip())
        numbers = []
        for t in tokens:
            try:
                numbers.append(int(t))
            except ValueError:
                pass  # 忽略非数字内容

        if len(numbers) % 6 != 0:
            QMessageBox.warning(self, "格式错误",
                                f"检测到的数字总数不是6的倍数（共{len(numbers)}个），请检查每组是否恰好6个数字。")
            return

        groups = [numbers[i:i+6] for i in range(0, len(numbers), 6)]
        results = []

        for g_idx, group in enumerate(groups, 1):
            # 检查阈值有效性
            if len(group) != 6:
                results.append(f"组 {g_idx}: 数字个数不为6，跳过。")
                continue

            # 计算各品级概率
            thresholds = group
            prev = 0
            probs = [0.0] * 5  # 白,蓝,紫,粉,黄
            total_prob = 0.0
            empty_prob = 0.0
            valid = True

            for i in range(5):
                raw_upper = thresholds[i]
                # 有效上界：原值若大于1000000则视为1000000，若为0或小于等于prev则区间无效
                if raw_upper <= 0:
                    eff_upper = 0
                else:
                    eff_upper = min(raw_upper, 1_000_000)

                if eff_upper > prev:
                    prob = (eff_upper - prev) / 1_000_000.0
                    probs[i] = prob
                    total_prob += prob
                    prev = eff_upper
                else:
                    # 后续品级概率均为0，剩余部分可能为空掉落
                    break

            empty_prob = 1.0 - total_prob
            if empty_prob < -1e-9:
                # 总概率超过100%，数据异常
                results.append(f"组 {g_idx}: 数据异常，总概率超过100%。")
                continue

            # 格式化输出
            lines = [f"组 {g_idx}:"]
            color_names = ["白色", "蓝色", "紫色", "粉色", "黄色"]
            for i in range(5):
                lines.append(f"  {color_names[i]}: {probs[i]*100:.4f}%")
            if empty_prob > 1e-9:
                lines.append(f"  空掉落: {empty_prob*100:.4f}%")
            total_display = total_prob + empty_prob
            lines.append(f"  总和: {total_display*100:.2f}%")
            results.append("\n".join(lines))

        self.result_text.setPlainText("\n\n".join(results))


if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = DropRateTool()
    window.show()
    sys.exit(app.exec())