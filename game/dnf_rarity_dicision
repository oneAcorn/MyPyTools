import sys
from PySide6.QtWidgets import (
    QApplication, QWidget, QLabel, QDoubleSpinBox,
    QPushButton, QLineEdit, QVBoxLayout, QHBoxLayout,
    QMessageBox, QTabWidget, QPlainTextEdit, QTableWidget,
    QTableWidgetItem, QHeaderView
)
from PySide6.QtCore import Qt


class DropRateTool(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("爆率工具 - 生成与分析")
        self.resize(680, 520)

        main_layout = QVBoxLayout()
        self.tabs = QTabWidget()
        main_layout.addWidget(self.tabs)

        self.create_generate_tab()
        self.create_analyze_tab()
        self.setLayout(main_layout)

    # ==================== 生成数组 ====================
    def create_generate_tab(self):
        tab = QWidget()
        layout = QVBoxLayout()
        layout.setSpacing(10)

        self.rarities = ["白", "蓝", "紫", "粉", "黄"]
        self.spin_boxes = []

        input_layout = QVBoxLayout()
        input_layout.setSpacing(5)
        for name in self.rarities:
            h_layout = QHBoxLayout()
            label = QLabel(f"{name}装爆率 (%):")
            label.setFixedWidth(100)
            spin = QDoubleSpinBox()
            spin.setRange(0.0, 100.0)
            spin.setDecimals(4)
            spin.setSuffix(" %")
            spin.setValue(0.0)
            spin.valueChanged.connect(self.update_total_display)
            h_layout.addWidget(label)
            h_layout.addWidget(spin)
            self.spin_boxes.append(spin)
            input_layout.addLayout(h_layout)
        layout.addLayout(input_layout)

        self.total_label = QLabel("当前总爆率：0.0000%")
        self.total_label.setStyleSheet("font-weight: bold; color: red;")
        layout.addWidget(self.total_label)

        self.btn_generate = QPushButton("生成数组")
        self.btn_generate.clicked.connect(self.generate_array)
        layout.addWidget(self.btn_generate)

        self.result_edit = QLineEdit()
        self.result_edit.setReadOnly(True)
        self.result_edit.setPlaceholderText("生成的数组将显示在这里...")
        layout.addWidget(self.result_edit)

        self.btn_copy = QPushButton("复制到剪贴板")
        self.btn_copy.clicked.connect(self.copy_to_clipboard)
        layout.addWidget(self.btn_copy)

        tab.setLayout(layout)
        self.tabs.addTab(tab, "生成数组")

    def update_total_display(self):
        percentages = [spin.value() for spin in self.spin_boxes]
        total = sum(percentages)
        self.total_label.setText(f"当前总爆率：{total:.4f}%")
        if abs(total - 100.0) > 0.0001:
            self.total_label.setStyleSheet("font-weight: bold; color: red;")
        else:
            self.total_label.setStyleSheet("font-weight: bold; color: green;")

    def generate_array(self):
        percentages = [spin.value() for spin in self.spin_boxes]
        total = sum(percentages)
        if abs(total - 100.0) > 0.0001:
            QMessageBox.warning(self, "爆率错误",
                                f"各品级爆率总和必须为 100%，当前总和为 {total:.4f}%。")
            return

        # 转换为百万分整数
        parts = [int(round(p * 10000)) for p in percentages]
        if sum(parts) != 1_000_000:
            QMessageBox.warning(self, "精度错误",
                                "整数转换后总和不为 1,000,000，请调整小数位数。")
            return

        # 找到最后一个概率 >0 的品级索引
        last_valid_idx = -1
        for i in range(5):
            if parts[i] > 0:
                last_valid_idx = i

        if last_valid_idx == -1:
            QMessageBox.warning(self, "错误", "至少需要设置一个品级的爆率大于 0。")
            return

        # 生成累积阈值（前5个）
        cumulative = 0
        values = []
        for i in range(5):
            if i <= last_valid_idx:
                cumulative += parts[i]
                values.append(cumulative)
            else:
                values.append(0)  # 无效品级置 0

        # 生成哨兵（第6个值）
        if last_valid_idx == 4:  # 有黄色
            sentinel = cumulative + 1  # 通常为 1000001
        else:
            sentinel = 0
        values.append(sentinel)

        # 格式：以制表符开头，每个数字间隔
        array_str = "\t" + "\t".join(str(v) for v in values)
        self.result_edit.setText(array_str)

    def copy_to_clipboard(self):
        text = self.result_edit.text()
        if not text:
            QMessageBox.information(self, "提示", "请先生成数组。")
            return
        QApplication.clipboard().setText(text)
        QMessageBox.information(self, "成功", "数组已复制到剪贴板。")

    # ==================== 分析数组 ====================
    def create_analyze_tab(self):
        tab = QWidget()
        layout = QVBoxLayout()

        layout.addWidget(QLabel("请将一组或多组数组粘贴到下方（每组为6个用制表符分隔的数字，每行一组）:"))

        self.analyze_input = QPlainTextEdit()
        self.analyze_input.setPlaceholderText(
            "示例：\n"
            "800000\t989900\t999900\t0\t0\t0\n"
            "330000\t750000\t950000\t980000\t1000000\t1000001"
        )
        layout.addWidget(self.analyze_input)

        self.btn_analyze = QPushButton("分析爆率")
        self.btn_analyze.clicked.connect(self.analyze_arrays)
        layout.addWidget(self.btn_analyze)

        self.table = QTableWidget()
        self.table.setColumnCount(7)
        self.table.setHorizontalHeaderLabels(["行号", "白(%)", "蓝(%)", "紫(%)", "粉(%)", "黄(%)", "总和(%)"])
        self.table.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        layout.addWidget(self.table)

        btn_clear = QPushButton("清空输入")
        btn_clear.clicked.connect(lambda: self.analyze_input.clear())
        layout.addWidget(btn_clear)

        tab.setLayout(layout)
        self.tabs.addTab(tab, "分析数组")

    def analyze_arrays(self):
        text = self.analyze_input.toPlainText().strip()
        if not text:
            QMessageBox.information(self, "提示", "请先粘贴数据。")
            return

        lines = text.splitlines()
        self.table.setRowCount(0)

        for line_idx, line in enumerate(lines):
            line = line.strip()
            if not line:
                continue
            if line.startswith('\t'):
                line = line[1:]

            parts = line.split('\t')
            numbers = []
            for p in parts:
                p = p.strip()
                if p:
                    try:
                        numbers.append(int(p))
                    except ValueError:
                        break
            if len(numbers) != 6:
                row = self.table.rowCount()
                self.table.insertRow(row)
                item = QTableWidgetItem(f"第{line_idx+1}行格式错误（需6个整数）")
                item.setToolTip(line)
                self.table.setSpan(row, 0, 1, 7)
                self.table.setItem(row, 0, item)
                continue

            a, b, c, d, e, sentinel = numbers

            # 确定有效上限：取前5个中最后一个 >0 的值
            base = 0
            for val in (e, d, c, b, a):
                if val > 0:
                    base = val
                    break
            if base == 0:
                row = self.table.rowCount()
                self.table.insertRow(row)
                item = QTableWidgetItem(f"第{line_idx+1}行无有效阈值")
                self.table.setSpan(row, 0, 1, 7)
                self.table.setItem(row, 0, item)
                continue

            # 计算各品级概率（分母为有效上限）
            def calc_rate(cur, prev):
                return (cur - prev) / base * 100 if cur > 0 else 0.0

            white_rate = calc_rate(a, 0)
            blue_rate = calc_rate(b, a)
            purple_rate = calc_rate(c, b)
            pink_rate = calc_rate(d, c)
            yellow_rate = calc_rate(e, d)
            total_rate = white_rate + blue_rate + purple_rate + pink_rate + yellow_rate

            row = self.table.rowCount()
            self.table.insertRow(row)
            self.table.setItem(row, 0, QTableWidgetItem(str(line_idx + 1)))
            self.table.setItem(row, 1, QTableWidgetItem(f"{white_rate:.4f}"))
            self.table.setItem(row, 2, QTableWidgetItem(f"{blue_rate:.4f}"))
            self.table.setItem(row, 3, QTableWidgetItem(f"{purple_rate:.4f}"))
            self.table.setItem(row, 4, QTableWidgetItem(f"{pink_rate:.4f}"))
            self.table.setItem(row, 5, QTableWidgetItem(f"{yellow_rate:.4f}"))

            sum_item = QTableWidgetItem(f"{total_rate:.4f}")
            if abs(total_rate - 100.0) > 0.01:
                sum_item.setForeground(Qt.red)
            else:
                sum_item.setForeground(Qt.green)
            self.table.setItem(row, 6, sum_item)

            # 若哨兵值异常则提示
            if e > 0 and sentinel != e + 1 and sentinel != 0:
                tip = f"⚠️ 哨兵异常 (黄阈值:{e}, 哨兵:{sentinel})"
                self.table.item(row, 0).setText(tip)
                self.table.item(row, 0).setToolTip(line)


if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = DropRateTool()
    window.show()
    sys.exit(app.exec())